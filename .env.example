# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cato_deal_intel

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://deal:deal@postgres:5432/deal_intel

# OpenAI
OPENAI_API_KEY=OPENAI_API_KEY
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODE=live
# LangSmith
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=LANGSMITH_API_KEY
LANGSMITH_PROJECT=cato-deal-intelligence


# Cost Manager
MAX_RUN_BUDGET_USD=0.05

PRICE_GPT_4_1_MINI_INPUT_PER_1M=0.40
PRICE_GPT_4_1_MINI_OUTPUT_PER_1M=1.60

PRICE_GPT_4_1_NANO_INPUT_PER_1M=0.10
PRICE_GPT_4_1_NANO_OUTPUT_PER_1M=0.40

# Logging
LOG_LEVEL=INFO

